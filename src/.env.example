HF_TOKEN=

# --- Environment ---
ENV=development                 # development | staging | production

# --- Models (optional overrides) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# --- Chunking / retrieval (optional overrides) ---
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K=5

# --- Generation (optional overrides) ---
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=500

# --- Security ---
CORS_ORIGINS=http://localhost:3000
REQUIRE_API_KEY=false            # set true in production
API_KEYS=

# --- Uploads ---
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=600
MAX_FILES_PER_UPLOAD=10

# --- Rate limiting ---
RATE_LIMIT_CHAT=10/minute
RATE_LIMIT_UPLOAD=5/minute

# --- Logging ---
LOG_LEVEL=INFO

# --- Web search fallback (optional overrides) ---
WEB_SEARCH_ENABLED=true
WEB_SEARCH_MAX_RESULTS=4
RETRIEVAL_SCORE_THRESHOLD=0.3

# --- Web search (Tavily) ---
# Free tier available at https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here